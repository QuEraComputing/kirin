stage @circuit fn @ghz(Qubit, Qubit, Qubit) -> Qubit;
specialize @circuit fn @ghz(Qubit, Qubit, Qubit) -> Qubit digraph ^dg0(%q0: Qubit, %q1: Qubit, %q2: Qubit) {
  %q0_h = h %q0 -> Qubit;
  %q0_out, %q1_out = cnot %q0_h, %q1 -> Qubit, Qubit;
  %q0_final, %q2_out = cnot %q0_out, %q2 -> Qubit, Qubit;
  yield %q0_final, %q1_out, %q2_out;
}
