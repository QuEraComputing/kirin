    where
        __L::Type: ::core::fmt::Display,
    {
        use kirin::pretty::DocAllocator;
        match self {
            ArithOps::Add {
                result: f_result,
                lhs: f_lhs,
                rhs: f_rhs,
            } => {
                (if namespace.is_empty() {
                    doc.text("add")
                } else {
                    let mut __s = namespace.join(".");
                    __s.push('.');
                    __s.push_str("add");
                    doc.text(__s)
