                    + ::kirin::pretty::PrettyPrint::pretty_print(f_lhs, doc)
                    + doc.text(", ")
                    + ::kirin::pretty::PrettyPrint::pretty_print(f_rhs, doc)
                    + doc.text(" -> ")
                    + ::kirin::pretty::PrettyPrint::pretty_print_type(f_result, doc)
            }
            ArithOps::Sub {
                result: f_result,
                lhs: f_lhs,
                rhs: f_rhs,
            } => {
                (if namespace.is_empty() {
                    doc.text("sub")
                } else {
                    let mut __s = namespace.join(".");
                    __s.push('.');
                    __s.push_str("sub");
                    doc.text(__s)
                }) + doc.text(" ")
                    + ::kirin::pretty::PrettyPrint::pretty_print(f_lhs, doc)
                    + doc.text(", ")
                    + ::kirin::pretty::PrettyPrint::pretty_print(f_rhs, doc)
                    + doc.text(" -> ")
                    + ::kirin::pretty::PrettyPrint::pretty_print_type(f_result, doc)
            }
        }
    }
    fn prints_result_names(&self) -> bool {
        false
