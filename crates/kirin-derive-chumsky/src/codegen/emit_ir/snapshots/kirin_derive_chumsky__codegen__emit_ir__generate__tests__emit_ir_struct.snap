#[automatically_derived]
impl<'tokens, 'src: 'tokens, TypeOutput, LanguageOutput, Language> kirin_chumsky::EmitIR<Language>
    for AddAST<'tokens, 'src, TypeOutput, LanguageOutput>
where
    Language: ::kirin::ir::Dialect + From<Add>,
    TypeOutput: Clone + PartialEq,
    LanguageOutput: Clone + PartialEq + 'tokens,
    SimpleType: kirin_chumsky::HasParser<'tokens, 'src> + 'tokens,
    <SimpleType as kirin_chumsky::HasParser<'tokens, 'src>>::Output:
        kirin_chumsky::EmitIR<Language, Output = <Language as ::kirin::ir::Dialect>::Type>,
{
    type Output = ::kirin::ir::Statement;
    fn emit(
        &self,
        ctx: &mut kirin_chumsky::EmitContext<'_, Language>,
    ) -> ::core::result::Result<Self::Output, kirin_chumsky::EmitError> {
        let Self {
            result: f_result,
            lhs: f_lhs,
            rhs: f_rhs,
            ..
        } = self;
        let f_result_ir = kirin_chumsky::EmitIR::emit(f_result, ctx)?;
        let f_lhs_ir = f_lhs.clone();
        let f_rhs_ir = f_rhs.clone();
        let dialect_variant: Add = Add {
            result: f_result_ir.into(),
            lhs: f_lhs_ir,
            rhs: f_rhs_ir,
        };
        Ok(ctx.stage.statement().definition(dialect_variant).new())
    }
}
