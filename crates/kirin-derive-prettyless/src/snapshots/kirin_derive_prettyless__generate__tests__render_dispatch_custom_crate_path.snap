impl kirin_prettyless::RenderDispatch for Stage {
    fn render_staged_function(
        &self,
        sf: kirin_ir::StagedFunction,
        config: &kirin_prettyless::Config,
        global_symbols: &kirin_ir::InternTable<String, kirin_ir::GlobalSymbol>,
    ) -> Result<Option<String>, std::fmt::Error> {
        match self {
            Stage::Source(s) => kirin_prettyless::RenderDispatch::render_staged_function(
                s,
                sf,
                config,
                global_symbols,
            ),
        }
    }
}
